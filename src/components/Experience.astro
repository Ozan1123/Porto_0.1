---
interface Experience {
  period: string;
  role: string;
  company: string;
  description: string;
}

const experiences: Experience[] = [
  {
    period: "Present",
    role: "Web & Game Developer",
    company: "Devacto it SMK PLUS PELITA NUSANTARA",
    description: "Participating in the Devacto it program, focusing on both Web Development and Game Development projects.",
  }
];
---

{experiences.length > 0 && (
<section id="experience" class="experience">
  <div class="experience-container">
    <div class="section-header reveal-bottom">
      <div class="section-label">
        <span class="label-line"></span>
        <span class="label-text">MY JOURNEY</span>
        <span class="label-line"></span>
      </div>
      <h2 class="section-title">Experience & Education</h2>
    </div>

    <div class="timeline-grid">
      {
        experiences.map((exp, index) => (
          <div
            class="experience-item reveal-bottom"
            style={`transition-delay: ${index * 0.1}s`}
          >
            <div class="item-period">{exp.period}</div>
            <div class="item-content">
              <h3 class="item-role">{exp.role}</h3>
              <div class="item-company">{exp.company}</div>
              <p class="item-description">{exp.description}</p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
)}

<style>
  .experience {
    padding: var(--space-24) 0;
    background: var(--white);
    position: relative;
  }

  .experience-container {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 var(--space-6);
  }

  .section-header {
    text-align: center;
    margin-bottom: var(--space-16);
  }

  .section-label {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-4);
    margin-bottom: var(--space-4);
  }

  .label-line {
    width: 60px;
    height: 1px;
    background: var(--silver);
  }

  .label-text {
    font-size: var(--text-sm);
    font-weight: var(--font-semibold);
    color: var(--night-blue);
    letter-spacing: 0.2em;
  }

  .section-title {
    font-size: var(--text-3xl);
    font-weight: var(--font-bold);
    color: var(--night-blue);
  }

  .timeline-grid {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }

  .experience-item {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: var(--space-8);
    background: var(--off-white);
    padding: var(--space-8);
    border-radius: var(--radius-lg);
    border-left: 4px solid var(--night-blue);
    transition: all var(--transition-base);
  }

  .experience-item:hover {
    transform: translateX(8px);
    box-shadow: var(--shadow-md);
    background: var(--white);
    border-color: var(--night-blue-light);
  }

  .item-period {
    font-size: var(--text-sm);
    font-weight: var(--font-bold);
    color: var(--night-blue-light);
    display: flex;
    align-items: flex-start;
    padding-top: 4px;
  }

  .item-content {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .item-role {
    font-size: var(--text-xl);
    font-weight: var(--font-bold);
    color: var(--night-blue);
    margin: 0;
  }

  .item-company {
    font-size: var(--text-base);
    font-weight: var(--font-medium);
    color: var(--gray-dark);
  }

  .item-description {
    font-size: var(--text-base);
    color: var(--gray);
    line-height: 1.6;
    margin-top: var(--space-2);
  }

  @media (max-width: 768px) {
    .experience-item {
      grid-template-columns: 1fr;
      gap: var(--space-4);
      padding: var(--space-6);
    }

    .item-period {
      padding-top: 0;
      margin-bottom: var(--space-2);
    }
  }
</style>
