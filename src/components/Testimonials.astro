---
// Testimonials Component
interface Testimonial {
  id: number;
  content: string;
  author: string;
  role: string;
  company: string;
  image?: string;
}

const testimonials: Testimonial[] = [];
---

{testimonials.length > 0 && (
<section id="testimonials" class="testimonials">
  <div class="testimonials-container">
    <!-- Section Header -->
    <div class="section-header reveal-bottom">
      <div class="section-label">
        <span class="label-line"></span>
        <span class="label-text">CLIENT REVIEWS</span>
        <span class="label-line"></span>
      </div>
      <h2 class="section-title">What People Say</h2>
    </div>

    <!-- Testimonials Slider -->
    <div class="testimonials-slider reveal-bottom reveal-delay-1">
      <div class="slider-track" id="testimonialTrack">
        {
          testimonials.map((test) => (
            <div class="testimonial-card">
              <div class="quote-icon">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="40"
                  height="40"
                  viewBox="0 0 24 24"
                  fill="var(--off-white)"
                  stroke="var(--silver)"
                  stroke-width="1"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="M3 21c3 0 7-1 7-8V5c0-1.25-.756-2.017-2-2H4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2 1 0 1 0 1 1v1c0 1-1 2-2 2s-1 .008-1 1.031V20c0 1 0 1 1 1z" />
                  <path d="M15 21c3 0 7-1 7-8V5c0-1.25-.757-2.017-2-2h-4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2h.75c0 2.25.25 4-2.75 4v3c0 1 0 1 1 1z" />
                </svg>
              </div>
              <p class="testimonial-content">"{test.content}"</p>
              <div class="testimonial-author">
                <div class="author-avatar">
                  {test.image ? (
                    <img src={test.image} alt={test.author} />
                  ) : (
                    <div class="avatar-placeholder">
                      {test.author.charAt(0)}
                    </div>
                  )}
                </div>
                <div class="author-info">
                  <h4 class="author-name">{test.author}</h4>
                  <span class="author-role">
                    {test.role}, {test.company}
                  </span>
                </div>
              </div>
            </div>
          ))
        }
      </div>

      <!-- Slider Controls -->
      <div class="slider-controls">
        <button
          class="slider-btn prev-btn"
          id="prevBtn"
          aria-label="Previous Testimonial"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><line x1="19" y1="12" x2="5" y2="12"></line><polyline
              points="12 19 5 12 12 5"></polyline></svg
          >
        </button>
        <div class="slider-dots" id="sliderDots">
          {
            testimonials.map((_, index) => (
              <button
                class={`dot ${index === 0 ? "active" : ""}`}
                data-index={index}
                aria-label={`Go to slide ${index + 1}`}
              />
            ))
          }
        </div>
        <button
          class="slider-btn next-btn"
          id="nextBtn"
          aria-label="Next Testimonial"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><line x1="5" y1="12" x2="19" y2="12"></line><polyline
              points="12 5 19 12 12 19"></polyline></svg
          >
        </button>
      </div>
    </div>
  </div>
</section>
)}

<script>
  // Simple slider logic
  document.addEventListener("DOMContentLoaded", () => {
    const track = document.getElementById("testimonialTrack");
    const prevBtn = document.getElementById("prevBtn");
    const nextBtn = document.getElementById("nextBtn");
    const dotsContainer = document.getElementById("sliderDots");

    if (!track || !prevBtn || !nextBtn || !dotsContainer) return;

    const cards = Array.from(track.children) as HTMLElement[];
    const dots = Array.from(dotsContainer.children) as HTMLElement[];

    let currentIndex = 0;
    const totalSlides = cards.length;

    function goToSlide(index: number) {
      if (index < 0) index = totalSlides - 1;
      if (index >= totalSlides) index = 0;

      currentIndex = index;

      // Calculate offset based on card width
      // Mobile 100%, Desktop 50%
      if (track) {
        const cardWidth = track.clientWidth > 768 ? 50 : 100;
        track.style.transform = `translateX(-${currentIndex * cardWidth}%)`;
      }

      // Update dots
      dots.forEach((dot, i) => {
        if (i === currentIndex) {
          dot.classList.add("active");
        } else {
          dot.classList.remove("active");
        }
      });
    }

    prevBtn.addEventListener("click", () => goToSlide(currentIndex - 1));
    nextBtn.addEventListener("click", () => goToSlide(currentIndex + 1));

    dots.forEach((dot, index) => {
      dot.addEventListener("click", () => goToSlide(index));
    });

    // Auto slide
    setInterval(() => {
      goToSlide(currentIndex + 1);
    }, 5000);
  });
</script>

<style>
  .testimonials {
    padding: var(--space-24) 0;
    background: var(--off-white);
    position: relative;
    overflow: hidden;
  }

  .testimonials-container {
    max-width: 1000px;
    margin: 0 auto;
    padding: 0 var(--space-6);
  }

  /* Section Header */
  .section-header {
    text-align: center;
    margin-bottom: var(--space-16);
  }

  .section-label {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-4);
    margin-bottom: var(--space-4);
  }

  .label-line {
    width: 60px;
    height: 1px;
    background: var(--silver);
  }

  .label-text {
    font-size: var(--text-sm);
    font-weight: var(--font-semibold);
    color: var(--night-blue);
    letter-spacing: 0.2em;
  }

  .section-title {
    font-size: var(--text-3xl);
    font-weight: var(--font-bold);
    color: var(--night-blue);
  }

  /* Slider */
  .testimonials-slider {
    position: relative;
    width: 100%;
    overflow: hidden;
  }

  .slider-track {
    display: flex;
    transition: transform 0.5s ease-in-out;
  }

  .testimonial-card {
    flex: 0 0 100%; /* Default mobile: 1 card visible */
    padding: var(--space-8);
    position: relative;
  }

  @media (min-width: 769px) {
    .testimonial-card {
      flex: 0 0 50%; /* Desktop: 2 cards visible */
    }
  }

  .quote-icon {
    position: absolute;
    top: var(--space-4);
    left: var(--space-4);
    z-index: 0;
  }

  .testimonial-content {
    position: relative;
    z-index: 1;
    font-size: var(--text-lg);
    color: var(--gray-dark);
    font-style: italic;
    line-height: 1.6;
    margin-bottom: var(--space-8);
    background: var(--white);
    padding: var(--space-8);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
    border: 1px solid var(--silver);
  }

  .testimonial-author {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    padding-left: var(--space-4);
  }

  .author-avatar {
    width: 50px;
    height: 50px;
    border-radius: 50%;
    overflow: hidden;
    background: var(--night-blue);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .author-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .avatar-placeholder {
    color: var(--white);
    font-size: var(--text-xl);
    font-weight: var(--font-bold);
  }

  .author-info {
    display: flex;
    flex-direction: column;
  }

  .author-name {
    font-size: var(--text-lg);
    font-weight: var(--font-bold);
    color: var(--night-blue);
    margin: 0;
  }

  .author-role {
    font-size: var(--text-sm);
    color: var(--gray);
  }

  /* Controls */
  .slider-controls {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-8);
    margin-top: var(--space-8);
  }

  .slider-btn {
    background: var(--white);
    border: 1px solid var(--silver);
    border-radius: 50%;
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--night-blue);
    cursor: pointer;
    transition: all var(--transition-fast);
  }

  .slider-btn:hover {
    background: var(--night-blue);
    color: var(--white);
    border-color: var(--night-blue);
  }

  .slider-dots {
    display: flex;
    gap: var(--space-2);
  }

  .dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--silver);
    border: none;
    cursor: pointer;
    padding: 0;
    transition: all var(--transition-fast);
  }

  .dot.active {
    background: var(--night-blue);
    transform: scale(1.2);
  }
</style>
